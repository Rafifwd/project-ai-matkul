# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
# In production (Vercel), frontend and backend share the same origin, so CORS is
# not needed — this variable is only relevant for local development.
# Default (if unset): http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# ── ML Hybrid Scoring ─────────────────────────────────────────────────────────
# Weight for the rule-based score in the hybrid formula (0.0–1.0).
# hybrid_score = HYBRID_ALPHA * rule_score + (1 - HYBRID_ALPHA) * ml_probability * 100
# Default: 0.5
# HYBRID_ALPHA=0.5

# ── Vercel (DO NOT SET MANUALLY) ──────────────────────────────────────────────
# These are injected automatically by Vercel at runtime.
# Setting them locally will block /api/train — do not set unless intentional.
# VERCEL=1
# VERCEL_ENV=production   # "production" | "preview" | "development"
